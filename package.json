{
  "name": "kintone-emulator",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "pnpm --filter @sonicgarden/kintone-emulator build && pnpm --filter @sonicgarden/kintone-emulator-server build && pnpm --filter @sonicgarden/kintone-emulator-cli build",
    "clean": "pnpm -r clean",
    "dev": "pnpm --filter @sonicgarden/kintone-emulator-server dev",
    "lint": "pnpm -r lint",
    "start": "pnpm --filter @sonicgarden/kintone-emulator-server start",
    "test": "pnpm --filter @sonicgarden/kintone-emulator test",
    "test:e2e": "pnpm --filter @sonicgarden/kintone-emulator-server test:e2e",
    "test:watch": "pnpm --filter @sonicgarden/kintone-emulator test:watch",
    "test:real-kintone": "pnpm --filter @sonicgarden/kintone-emulator exec vitest run --mode real-kintone",
    "typecheck": "pnpm -r typecheck",
    "pack": "pnpm --filter @sonicgarden/kintone-emulator pack --pack-destination ./tmp",
    "cli": "node packages/cli/dist/cli.js"
  },
  "devDependencies": {
    "@kintone/rest-api-client": "^5.6.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.28.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}

{
  "name": "kintone-emulator",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "pnpm --filter @kintone-emulator/core build && pnpm --filter @kintone-emulator/server build && pnpm --filter @kintone-emulator/cli build",
    "clean": "pnpm -r clean",
    "dev": "pnpm --filter @kintone-emulator/server dev",
    "lint": "pnpm -r lint",
    "start": "pnpm --filter @kintone-emulator/server start",
    "test": "pnpm --filter @kintone-emulator/core test",
    "test:e2e": "pnpm --filter @kintone-emulator/server test:e2e",
    "test:watch": "pnpm --filter @kintone-emulator/core test:watch",
    "typecheck": "pnpm -r typecheck",
    "pack": "pnpm --filter @kintone-emulator/core pack --pack-destination ./tmp",
    "cli": "node packages/cli/dist/cli.js"
  },
  "devDependencies": {
    "@kintone/rest-api-client": "^5.6.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.38.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.28.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.1.6",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

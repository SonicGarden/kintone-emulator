{
  "name": "@sonicgarden/kintone-emulator-server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "pnpm typecheck && react-router build",
    "clean": "rm -rf build ./node_modules/.cache/eslint .react-router",
    "dev": "react-router dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "PORT=12345 HOST=0.0.0.0 react-router-serve ./build/server/index.js",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@react-router/node": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@sonicgarden/kintone-emulator": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "isbot": "^4.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.2",
    "@react-router/fs-routes": "^7.14.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}

{
  "name": "@sonicgarden/kintone-emulator",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-support": {
      "types": "./dist/test-support/index.d.ts",
      "import": "./dist/test-support/index.js"
    },
    "./test-support/vitest": {
      "types": "./dist/test-support/vitest.d.ts",
      "import": "./dist/test-support/vitest.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "peerDependencies": {
    "@kintone/rest-api-client": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@kintone/rest-api-client": { "optional": true }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist ./node_modules/.cache/eslint",
    "prepack": "pnpm build",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dedent": "^1.5.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "vite": "^6.4.2"
  }
}
